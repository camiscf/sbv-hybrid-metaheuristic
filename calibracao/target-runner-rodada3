#!/bin/bash
# target-runner para irace — Rodada 3: GA+RVND+Mineração (9 params)
# Parada por gerações (não tempo). Usa 50 gerações para avaliação rápida.

CONFIG_ID=$1
INSTANCE_ID=$2
SEED=$3
EDICAO=$4
TEMPORADA=$5
shift 5

EXE="../src/tcc2"

RESULT=$($EXE $EDICAO $TEMPORADA 1 gam --seed $SEED --max-geracoes 50 --irace $@ 2>/dev/null | tail -1)

echo "$RESULT"
